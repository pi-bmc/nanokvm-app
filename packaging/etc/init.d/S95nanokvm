#!/bin/sh
# NanoKVM BMC Service
#
# We stage the server binary (and any sibling assets) into a runtime directory
# on each start, then run the daemon from there. Staging keeps the daemon
# decoupled from ${SRC_DIR}: an in-place upgrade can rewrite
# /kvmapp/server/NanoKVM-Server while a previous instance is still running, and
# the next `start` picks it up via an atomic rename.
#
# The runtime dir lives on the SAME writable ext4 filesystem as ${SRC_DIR}
# (NOT on the /tmp RAM disk). /tmp -> /var/tmp -> /var/volatile/tmp is a tmpfs
# sized at 50% of RAM (~103 MB on this 207 MB board) that also backs /var/log.
# The server binary is ~53 MB, and the atomic stage briefly holds two copies
# (old staged + new temp), so staging into /tmp peaked at ~106 MB and blew past
# the tmpfs size -> ENOSPC ("/tmp 100% full") on every restart/upgrade, plus it
# permanently burned >50% of RAM on a single file. /kvmapp is ordinary rw ext4
# with >1 GB free, so staging there is atomic (same-fs rename), costs no RAM,
# and never runs out of space.
#
# NB: the upstream packaging/etc/init.d/S95nanokvm drives start-stop-daemon
# with Debian-only options -O (redirect output to logfile) and -d (chdir),
# which BusyBox's start-stop-daemon does not implement ("unrecognized option:
# O"/"d"), so the daemon silently fails to launch on this image. This variant
# uses only BusyBox-supported options. Neither dropped option is needed here:
# the server chdir-independently reads /etc/kvm and writes its own log to
# /var/log/NanoKVM-Server.log, so -d/-O are unnecessary.

DAEMON="NanoKVM-Server"
SRC_DIR="/kvmapp/server"
RUN_DIR="/kvmapp/run"
BIN="${RUN_DIR}/${DAEMON}"
# PID file on the /run tmpfs so it is cleared on every boot -- a runtime dir on
# persistent ext4 would otherwise keep a stale pidfile across a crash/power cut.
PID_FILE="/run/${DAEMON}.pid"

stage() {
    [ -d "${SRC_DIR}" ] || { echo "missing ${SRC_DIR}"; return 1; }
    mkdir -p "${RUN_DIR}"

    # Copy sibling assets in place. cp will refuse to overwrite a running
    # ELF (ETXTBSY) on Linux, so the daemon binary itself is staged
    # separately below via a temp file + atomic rename.
    for entry in "${SRC_DIR}"/* "${SRC_DIR}"/.[!.]*; do
        [ -e "${entry}" ] || continue
        base=$(basename "${entry}")
        [ "${base}" = "${DAEMON}" ] && continue
        cp -RpP "${entry}" "${RUN_DIR}/" || return 1
    done

    # Skip re-copying the ~53 MB binary when the staged copy already matches the
    # source (same size AND mtime). Avoids a 53 MB SD write on every boot; an
    # upgrade rewrites the source (new mtime/size) and re-triggers staging.
    src_sig=$(stat -c '%s:%Y' "${SRC_DIR}/${DAEMON}" 2>/dev/null)
    run_sig=$(stat -c '%s:%Y' "${BIN}" 2>/dev/null)
    if [ -n "${src_sig}" ] && [ "${src_sig}" = "${run_sig}" ]; then
        return 0
    fi

    # Stage the daemon binary atomically:
    #   1. cp to a temp path on the same filesystem so cp doesn't touch the
    #      currently-mapped inode (no ETXTBSY) and the rename stays atomic.
    #   2. rename(2) over the live path. The kernel unlinks the old inode
    #      but lets the running process keep its open mapping until exit;
    #      the next `start` execs the new file.
    tmp="${RUN_DIR}/.${DAEMON}.new.$$"
    cp -p "${SRC_DIR}/${DAEMON}" "${tmp}" || { rm -f "${tmp}"; return 1; }
    chmod +x "${tmp}"
    # Preserve source mtime on the staged copy so the skip check above matches.
    touch -r "${SRC_DIR}/${DAEMON}" "${tmp}" 2>/dev/null
    mv -f "${tmp}" "${BIN}" || { rm -f "${tmp}"; return 1; }
    return 0
}

start() {
    stage || { echo "FAIL"; return 1; }
    # -S start, -b background, -m write pidfile with the child PID, -o exit 0
    # if already running, -p pidfile, -x the daemon binary (matches on comm
    # "NanoKVM-Server" for stop/status).
    start-stop-daemon -S -b -m -o -p "${PID_FILE}" -x "${BIN}" \
        && echo "OK" || echo "FAIL"
}

stop() {
    start-stop-daemon -K -o -p "${PID_FILE}" -x "${BIN}"
    ret=$?
    rm -f "${PID_FILE}"
    [ ${ret} -eq 0 ] && echo "OK" || echo "FAIL"
}

status() {
    # -K -t: test only (don't signal); exit 0 if the process is running.
    if start-stop-daemon -K -t -q -p "${PID_FILE}" -x "${BIN}"; then
        echo "NanoKVM is running (PID $(cat "${PID_FILE}" 2>/dev/null))"
    else
        echo "NanoKVM is not running"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    status)  status ;;
    restart) stop; sleep 1; start ;;
    *)
        echo "Usage: $0 {start|stop|status|restart}"
        exit 1
        ;;
esac
